// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String @id @default(uuid())
  name        String
  email       String @unique
  password    String
  role        String
  occupation  String
  institution String
  grade       String
  avatar      String
  about_me    String

  createdAt    DateTime       @default(now())
  activities   Activity[]
  savedSchools Saved_School[]
}

model College {
  id              String         @id @default(uuid())
  college_name    String         @unique
  type            String
  about           String
  address         String
  college_image   String
  email           String
  fb_page         String
  latitude        Float
  longitude       Float
  logo_link       String
  program_numbers Int
  program_offered String[]
  ranking         Int
  rating          Float
  tags            String[]
  telephone       String
  savedSchools    Saved_School[]
}

model Scholarship {
  id                   String   @id @default(uuid())
  scholarship_name     String
  scholarship_icon     String
  allowance            String
  about                String
  application_steps    String[]
  application_timeline Json[]
  benefits             Json[]
  color                String
  start_time           DateTime
  end_time             DateTime
  duration             Int
  eligibility          String[]
  government           Boolean
  grant_title          Json
  min_gwa              Float
  organization_name    Json
  required_documents   String[]
  service_obligation   Json
  tags                 String[]
  likes                Int
  website              String
}

model Center {
  id              String   @id @default(uuid())
  title           String   @unique
  subtitle        String
  instructor      String
  managed_by      String
  about_center    Json
  program_overvew Json
  offers          String[]
  coverage        String[]
  description     String
  email           String
  emoji           String
  exams           String[]
  best_seller     Boolean
  location        String
  modalities      String
  current_price   Float
  last_price      Float?
  phone           String
  rating_count    Int
  rating_num      Float
  stars           String?
  website         String
  beneficiaries   String[]
}

model Activity {
  id          String   @id @default(uuid())
  user_id     String
  date        DateTime @default(now())
  description String
  user        User     @relation(fields: [user_id], references: [id])
}

model Saved_School {
  id         String  @id @default(uuid())
  user_id    String
  college_id String
  user       User    @relation(fields: [user_id], references: [id])
  college    College @relation(fields: [college_id], references: [id])
}
